# Server
PORT=3000
NODE_ENV=development

# Auth (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# Database (Railway PostgreSQL URL)
DATABASE_URL=

# AI (get from aistudio.google.com)
GEMINI_API_KEY=

# Email (get from resend.com)
RESEND_API_KEY=

# Scheduler (default: every 5 minutes)
REMINDER_CRON_SCHEDULE=*/5 * * * *